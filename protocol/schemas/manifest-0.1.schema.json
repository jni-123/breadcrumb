{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadcrumb.dev/schemas/manifest-0.1.schema.json",
  "title": "Breadcrumb owner manifest 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "submission_url", "accepted_events", "privacy"],
  "properties": {
    "version": { "const": "0.1" },
    "submission_url": { "type": "string", "minLength": 1, "maxLength": 2048 },
    "protocol_url": { "type": "string", "format": "uri", "maxLength": 2048 },
    "report_schema_url": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048
    },
    "documentation_url": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048
    },
    "direct_submission": { "const": true },
    "accepted_events": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["task_failed", "task_degraded", "task_succeeded_with_friction"]
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_user_prompt",
        "allow_file_contents",
        "allow_screenshots",
        "max_payload_bytes"
      ],
      "properties": {
        "allow_user_prompt": { "type": "boolean" },
        "allow_file_contents": { "type": "boolean" },
        "allow_screenshots": { "type": "boolean" },
        "max_payload_bytes": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 1048576
        }
      }
    },
    "allow_anonymous_agents": { "type": "boolean", "default": true },
    "authentication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["none", "bearer"] }
      }
    }
  }
}
