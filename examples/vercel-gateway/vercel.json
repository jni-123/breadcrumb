{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "crons": [
    {
      "path": "/api/prune-rate-limits",
      "schedule": "17 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/breadcrumb",
      "destination": "/api/breadcrumb-manifest"
    }
  ],
  "headers": [
    {
      "source": "/api/agent-feedback",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
