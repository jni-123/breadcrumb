# Use the pooled PostgreSQL connection string supplied by the Vercel Marketplace integration.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Stable production origin. Do not use a deployment preview URL.
BREADCRUMB_PUBLIC_ORIGIN=https://feedback.example.com

# The only target origin this single-owner gateway accepts reports for.
BREADCRUMB_TARGET_ORIGIN=https://docs.example.com

# Generate at least 32 random characters. Used only to HMAC rate-limit keys.
BREADCRUMB_RATE_LIMIT_SECRET=replace-with-a-random-secret-at-least-32-characters

# Vercel sends this bearer secret to the scheduled rate-limit cleanup route.
CRON_SECRET=replace-with-a-separate-random-secret

BREADCRUMB_MAX_REPORTS_PER_MINUTE=20
